    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "google-auth-library": "^10.9.0",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.14",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "zod": "^3.23.8"
  }
